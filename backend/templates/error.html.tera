{% extends "base" %}

{% block title %}{{ code }} | my-6-games{% endblock %}

{% block content %}
<div class="text-center py-16">
  <div class="text-7xl font-bold text-purple-400 mb-4">{{ code }}</div>
  <h1 class="text-2xl font-bold text-white mb-3">{{ reason }}</h1>
  <p class="text-gray-400 mb-10">{{ description }}</p>
  <a href="/" class="px-6 py-3 bg-purple-600 hover:bg-purple-500 text-white font-semibold rounded-lg transition-colors">
    トップページへ
  </a>
</div>
{% endblock %}